# Django Backend Configuration

# Database
DATABASE_NAME=tourgo_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Django
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*.railway.app

# CORS - Update with your frontend URL
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,https://your-frontend-domain.com

# API Settings
API_BASE_URL=http://localhost:8000
API_TIMEOUT=30

# Payment Integration (bKash)
BKASH_APP_ID=your_bkash_app_id
BKASH_APP_SECRET=your_bkash_secret
BKASH_USERNAME=your_bkash_username
BKASH_PASSWORD=your_bkash_password
BKASH_MODE=sandbox

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# AWS/Storage (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
